# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/antigravity_payroll

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# ─── Email (Nodemailer / Gmail SMTP) ─────────────────────────────────────────
# Leave blank to disable email features (payslip emails, password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.email@gmail.com
APP_PASSWORD=your_google_app_password

# ─── Frontend URL (used in password reset emails) ─────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── File Storage ─────────────────────────────────────────────────────────────
# Documents are stored under backend/documents/ by default.
# No additional config required for local disk storage.
